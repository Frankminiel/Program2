@page
@model Todos_Podemos.Pages.Players.CreateModel

<div class="container mt-4">
    <h2>Crear Jugador</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Player.Name" class="form-label"></label>
            <input asp-for="Player.Name" class="form-control" />
            <span asp-validation-for="Player.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Player.Age" class="form-label"></label>
            <input asp-for="Player.Age" class="form-control" />
            <span asp-validation-for="Player.Age" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Player.RankingPoints" class="form-label"></label>
            <input asp-for="Player.RankingPoints" class="form-control" />
            <span asp-validation-for="Player.RankingPoints" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Player.Category" class="form-label"></label>
            <input asp-for="Player.Category" class="form-control" />
            <span asp-validation-for="Player.Category" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}